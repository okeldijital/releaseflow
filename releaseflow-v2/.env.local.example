# =============================================================================
# ReleaseFlow — Environment Variables
# =============================================================================
# Copy this file to .env.local and fill in the values.
#   cp .env.local.example .env.local
# =============================================================================

# Firebase — required for authentication and database.
# Get these from your Firebase project console:
#   https://console.firebase.google.com/project/_/settings/general
# Under "Your apps" → Web App → "Firebase SDK snippet" → Config.

NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSyD2IUmM5c-Uw9pbtmuYamJLOV0srlSoCUo
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=releaseflow-prod.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=releaseflow-prod
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=992191005620
NEXT_PUBLIC_FIREBASE_APP_ID=1:992191005620:web:29df79acddc718c1afe8e1

# Firebase Emulator (optional — local development only)
# NEXT_PUBLIC_EMULATOR_HOST=localhost

# Cloudinary
# Server secrets (never expose API key/secret to the browser bundle)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# Public delivery name only (safe for client MediaUrlService / thumbnails)
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=
