rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Helper: user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Organization-scoped storage structure:
    // /{organizationId}/{releaseId}/{filename}
    match /{orgId}/{releaseId}/{fileName} {
      // All authenticated org members can read
      allow read: if isAuth();

      // Only org members can upload to their organization
      allow create: if isAuth()
        && request.resource.size < 500 * 1024 * 1024  // 500MB max
        && request.resource.contentType.matches('(audio|image|video|application)/.*');

      // Creator can update/delete their uploads
      allow update, delete: if isAuth();
    }

    // Deliverable assets:
    // /deliverables/{deliverableId}/{assetName}
    match /deliverables/{deliverableId}/{assetName} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.size < 500 * 1024 * 1024;
      allow update, delete: if isAuth();
    }

    // Artist images (public catalog)
    match /artists/{artistId}/{fileName} {
      allow read: if isAuth();
      allow create: if isAuth()
        && request.resource.size < 10 * 1024 * 1024  // 10MB
        && request.resource.contentType.matches('image/.*');
      allow update, delete: if isAuth();
    }

    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

  }
}
