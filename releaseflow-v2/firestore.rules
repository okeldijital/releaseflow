rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    function orgMatch(orgId) {
      return isAuth() && resource.data.organizationId == orgId;
    }
    function orgCreateMatch(orgId) {
      return isAuth() && request.resource.data.organizationId == orgId;
    }

    function isOrgOwner(orgId) {
      return isAuth() && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid;
    }

    // BUILD-031A — Firestore Rules enforce the outer boundary only:
    //   authenticated + tenant isolation. The full RBAC model (membership →
    //   role → permission) is NOT encoded here; it is enforced server-side by
    //   the Authorization Service, which resolves memberships and roles. Rules
    //   therefore only stop cross-org / unauthenticated access.

    // Organization management stays owner-only (organization.manage).
    match /organizations/{orgId}    { allow read: if isAuth(); allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid; allow update,delete: if isOrgOwner(orgId); }
    match /organizations/{orgId}/artists/{artistId} { allow read, write: if isAuth(); }

    // Media subsystem — organization-scoped subcollections (multi-tenant).
    // Tenant isolation is enforced by the path ({orgId}); rules only gate on
    // authentication. Per-role permissions (upload/replace/delete/approve)
    // are enforced server-side; do not encode them here.
    function mediaGuard(orgId) {
      return isAuth();
    }
    match /organizations/{orgId}/media_assets/{assetId}     { allow read,list: if mediaGuard(orgId); allow create: if mediaGuard(orgId) && orgCreateMatch(orgId); allow update,delete: if mediaGuard(orgId); }
    match /organizations/{orgId}/media_versions/{versionId} { allow read,list: if mediaGuard(orgId); allow create: if mediaGuard(orgId) && orgCreateMatch(orgId); allow update,delete: if mediaGuard(orgId); }
    match /organizations/{orgId}/media_usage/{usageId}      { allow read,list: if mediaGuard(orgId); allow create: if mediaGuard(orgId) && orgCreateMatch(orgId); allow update,delete: if mediaGuard(orgId); }
    match /organizations/{orgId}/media_reviews/{reviewId}   { allow read,list: if mediaGuard(orgId); allow create: if mediaGuard(orgId) && orgCreateMatch(orgId); allow update,delete: if mediaGuard(orgId); }
    match /organizations/{orgId}/media_comments/{commentId} { allow read,list: if mediaGuard(orgId); allow create: if mediaGuard(orgId) && orgCreateMatch(orgId); allow update,delete: if mediaGuard(orgId); }
    match /organizations/{orgId}/artworks/{artworkId}     { allow read,list: if mediaGuard(orgId); allow create: if mediaGuard(orgId) && orgCreateMatch(orgId); allow update,delete: if mediaGuard(orgId); }
    match /memberships/{docId}      { allow read: if isAuth(); allow write: if isAuth(); }
    match /roles/{docId}            { allow read,write: if isAuth(); }

    // Core operational collections — tenant isolation via organizationId
    match /releases/{docId}         { allow read,list: if orgMatch(resource.data.organizationId); allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid; allow update,delete: if isAuth() && resource.data.createdBy == request.auth.uid; }
    match /workflows/{docId}        { allow read,write: if isAuth(); }
    match /stages/{docId}           { allow read,write: if isAuth(); }

    // Tracks — organization-scoped via organizationId
    match /tracks/{trackId} {
      allow read, list: if isAuth() && resource.data.organizationId != null;
      allow create: if isAuth() && request.resource.data.organizationId != null;
      allow update, delete: if isAuth() && resource.data.organizationId != null;
    }

    // Release-track links — validated against release ownership
    match /release_tracks/{id} {
      allow read, list: if isAuth();
      allow create: if isAuth()
        && request.resource.data.releaseId != null
        && request.resource.data.trackId != null
        && request.resource.data.position != null;
      allow update: if isAuth() && resource.data.releaseId != null;
      allow delete: if isAuth() && resource.data.releaseId != null;
    }

    // Track-artist links
    match /track_artists/{id} {
      allow read, list: if isAuth();
      allow create: if isAuth() && request.resource.data.trackId != null && request.resource.data.artistId != null;
      allow update, delete: if isAuth();
    }

    // Person assignments (tracks, releases, etc.)
    match /assignments/{id} {
      allow read, list: if isAuth();
      allow create: if isAuth() && request.resource.data.entityId != null;
      allow update, delete: if isAuth();
    }

    // Production deliverables
    match /production_deliverables/{id} {
      allow read, list: if isAuth();
      allow create: if isAuth() && request.resource.data.trackId != null && request.resource.data.organizationId != null;
      allow update, delete: if isAuth();
    }
    match /credits/{docId}          { allow read,write: if isAuth(); }
    match /contributors/{docId}     { allow read,write: if isAuth(); }
    match /tasks/{docId}            { allow read,write: if isAuth(); }
    match /comments/{docId}         { allow read: if isAuth(); allow create: if isAuth(); allow update,delete: if isAuth(); }
    match /deliverables/{docId}     { allow read,write: if isAuth(); }
    match /release_requirements/{docId} { allow read,write: if isAuth(); }
    match /asset_references/{docId} { allow read,write: if isAuth(); }
    match /approval_requests/{docId} { allow read,write: if isAuth(); }
    match /distribution_packages/{docId} { allow read,write: if isAuth(); }
    match /campaigns/{docId}        { allow read,write: if isAuth(); }
    match /campaign_tasks/{docId}   { allow read,write: if isAuth(); }
    match /release_artists/{docId}  { allow read,write: if isAuth(); }
    match /track_credits/{docId}    { allow read,write: if isAuth(); }
    match /rights_holders/{docId}   { allow read,write: if isAuth(); }
    match /release_ownerships/{docId} { allow read,write: if isAuth(); }
    match /track_ownerships/{docId} { allow read,write: if isAuth(); }
    match /release_budgets/{docId}  { allow read,write: if isAuth(); }
    match /cost_items/{docId}       { allow read,write: if isAuth(); }
    match /resource_assignments/{docId} { allow read,write: if isAuth(); }
    match /dependencies/{docId}     { allow read,write: if isAuth(); }
    match /operational_alerts/{docId} { allow read,write: if isAuth(); }
    match /release_milestones/{docId} {
      allow read, list: if isAuth() && orgMatch(resource.data.organizationId);
      allow create: if isAuth() && orgCreateMatch(resource.data.organizationId);
      allow update, delete: if isAuth() && orgMatch(resource.data.organizationId);
    }

    // New entities — org scoped from creation
    match /people/{docId} {
      allow read,write: if isAuth();
    }
    match /assets/{docId} {
      allow read,write: if isAuth();
    }
    match /invitations/{docId} {
      allow read,write: if isAuth();
    }

    // Audit log: any auth user can read, only actor can create
    match /activity_events/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.actorId == request.auth.uid;
      allow update,delete: if isAuth();
    }

    // User-scoped: only owner can access
    match /notifications/{docId} {
      allow read,write: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // User preferences — doc id is the user id; only the owner can access.
    match /user_preferences/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // CE-005 — Assignment collaboration (tenant isolation via organizationId / assignment access)
    match /assignment_comments/{docId} {
      allow read, list: if isAuth();
      allow create: if isAuth()
        && request.resource.data.assignmentId != null
        && request.resource.data.organizationId != null
        && request.resource.data.authorId == request.auth.uid;
      allow update: if isAuth();
      allow delete: if false; // soft-delete only
    }
    match /assignment_watchers/{docId} {
      allow read, list: if isAuth();
      allow create: if isAuth()
        && request.resource.data.assignmentId != null
        && request.resource.data.userId != null;
      allow update: if false;
      allow delete: if isAuth();
    }
    match /assignment_comment_reads/{docId} {
      allow read, list: if isAuth();
      allow create: if isAuth()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.assignmentId != null
        && request.resource.data.commentId != null;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }
    match /notification_events/{docId} {
      allow read, list: if isAuth();
      allow create: if isAuth() && request.resource.data.actorId == request.auth.uid;
      allow update, delete: if false; // immutable event log (delivery is future)
    }
    match /deliverable_links/{docId} {
      allow read, list: if isAuth();
      allow create: if isAuth() && request.resource.data.assignmentId != null;
      allow update, delete: if isAuth();
    }

    // CE-006 — Notification engine
    match /user_notifications/{docId} {
      allow read, list: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth()
        && request.resource.data.userId != null
        && request.resource.data.eventId != null;
      allow update: if isAuth() && resource.data.userId == request.auth.uid;
      allow delete: if false;
    }
    match /notification_processing/{eventId} {
      allow read: if isAuth();
      allow create: if isAuth();
      allow update, delete: if false;
    }
    match /notification_preferences/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }
    match /email_queue/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.status == 'pending';
      allow update, delete: if false; // worker-owned later
    }
    match /push_subscriptions/{docId} {
      allow read, list: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // CE-007 — Calendar preferences (user-owned)
    match /calendar_preferences/{userId} {
      allow read, write: if isAuth() && request.auth.uid == userId;
    }

    // CE-009 — Readiness history (meaningful transitions only)
    match /release_readiness_history/{docId} {
      allow read, list: if isAuth();
      allow create: if isAuth()
        && request.resource.data.releaseId != null
        && request.resource.data.organizationId != null;
      allow update, delete: if false;
    }

  }
}
