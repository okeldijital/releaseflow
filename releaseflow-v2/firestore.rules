rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: user is authenticated
    function isAuth() {
      return request.auth != null;
    }

    // Helper: user owns the doc
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Helper: user belongs to the organization (reads membership)
    function isOrgMember(orgId) {
      return exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + orgId));
    }

    // Organizations: any auth user can read, creators can write their own
    match /organizations/{orgId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid;
      allow update, delete: if isAuth() && resource.data.ownerId == request.auth.uid;
    }

    // Memberships: users read their own, org owners can manage
    match /memberships/{membershipId} {
      allow read: if isAuth() && (request.auth.uid in resource.data || request.auth.uid == resource.data.userId);
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

    // Releases: org members can read, create with orgId
    match /releases/{releaseId} {
      allow read: if isAuth() && isOrgMember(resource.data.organizationId);
      allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid;
      allow update: if isAuth() && (
        resource.data.createdBy == request.auth.uid ||
        exists(/databases/$(database)/documents/memberships/$(request.auth.uid + '_' + resource.data.organizationId))
      );
      allow delete: if isAuth() && resource.data.createdBy == request.auth.uid;
    }

    // Workflows, Stages, Tasks, Deliverables, Requirements: scoped to release
    match /{collection}/{docId} {
      allow read: if isAuth();
      allow write: if isAuth() && request.resource.data.keys().hasAny(['releaseId', 'organizationId']);
    }

    // Activities: auth users can read/write their own
    match /activities/{activityId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.actorId == request.auth.uid;
    }

    // Notifications: users can only read/write their own
    match /notifications/{notifId} {
      allow read, write: if isAuth() && resource.data.userId == request.auth.uid;
    }

    // Artists, Rights Holders: any auth user can CRUD (global catalog)
    match /{collection}/{docId} {
      allow read: if isAuth();
      allow write: if isAuth();
    }

  }
}
