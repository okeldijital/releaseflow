rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() { return request.auth != null; }

    function orgMatch(orgId) {
      return isAuth() && resource.data.organizationId == orgId;
    }
    function orgCreateMatch(orgId) {
      return isAuth() && request.resource.data.organizationId == orgId;
    }

    function isOrgOwner(orgId) {
      return isAuth() && get(/databases/$(database)/documents/organizations/$(orgId)).data.ownerId == request.auth.uid;
    }

    // Organization-scoped: only auth users of same org can read/write
    // Organization management
    match /organizations/{orgId}    { allow read: if isAuth(); allow create: if isAuth() && request.resource.data.ownerId == request.auth.uid; allow update,delete: if isOrgOwner(orgId); }
    match /organizations/{orgId}/artists/{artistId} { allow read, write: if isAuth(); }
    match /memberships/{docId}      { allow read: if isAuth(); allow write: if isAuth(); }
    match /roles/{docId}            { allow read,write: if isAuth(); }

    // Core operational collections — tenant isolation via organizationId
    match /releases/{docId}         { allow read,list: if orgMatch(resource.data.organizationId); allow create: if isAuth() && request.resource.data.createdBy == request.auth.uid; allow update,delete: if isAuth() && resource.data.createdBy == request.auth.uid; }
    match /workflows/{docId}        { allow read,write: if isAuth(); }
    match /stages/{docId}           { allow read,write: if isAuth(); }

    // Tracks — organization-scoped via organizationId
    match /tracks/{trackId} {
      allow read, list: if isAuth() && resource.data.organizationId != null;
      allow create: if isAuth() && request.resource.data.organizationId != null;
      allow update, delete: if isAuth() && resource.data.organizationId != null;
    }

    // Release-track links — validated against release ownership
    match /release_tracks/{id} {
      allow read, list: if isAuth();
      allow create: if isAuth()
        && request.resource.data.releaseId != null
        && request.resource.data.trackId != null
        && request.resource.data.position != null;
      allow update: if isAuth() && resource.data.releaseId != null;
      allow delete: if isAuth() && resource.data.releaseId != null;
    }
    match /contributors/{docId}     { allow read,write: if isAuth(); }
    match /tasks/{docId}            { allow read,write: if isAuth(); }
    match /comments/{docId}         { allow read: if isAuth(); allow create: if isAuth(); allow update,delete: if isAuth(); }
    match /deliverables/{docId}     { allow read,write: if isAuth(); }
    match /release_requirements/{docId} { allow read,write: if isAuth(); }
    match /asset_references/{docId} { allow read,write: if isAuth(); }
    match /approval_requests/{docId} { allow read,write: if isAuth(); }
    match /distribution_packages/{docId} { allow read,write: if isAuth(); }
    match /campaigns/{docId}        { allow read,write: if isAuth(); }
    match /campaign_tasks/{docId}   { allow read,write: if isAuth(); }
    match /release_artists/{docId}  { allow read,write: if isAuth(); }
    match /track_credits/{docId}    { allow read,write: if isAuth(); }
    match /rights_holders/{docId}   { allow read,write: if isAuth(); }
    match /release_ownerships/{docId} { allow read,write: if isAuth(); }
    match /track_ownerships/{docId} { allow read,write: if isAuth(); }
    match /release_budgets/{docId}  { allow read,write: if isAuth(); }
    match /cost_items/{docId}       { allow read,write: if isAuth(); }
    match /resource_assignments/{docId} { allow read,write: if isAuth(); }
    match /dependencies/{docId}     { allow read,write: if isAuth(); }
    match /operational_alerts/{docId} { allow read,write: if isAuth(); }

    // New entities — org scoped from creation
    match /people/{docId} {
      allow read,write: if isAuth();
    }
    match /assets/{docId} {
      allow read,write: if isAuth();
    }

    // Audit log: any auth user can read, only actor can create
    match /activities/{docId} {
      allow read: if isAuth();
      allow create: if isAuth() && request.resource.data.actorId == request.auth.uid;
      allow update,delete: if isAuth();
    }

    // User-scoped: only owner can access
    match /notifications/{docId} {
      allow read,write: if isAuth() && resource.data.userId == request.auth.uid;
      allow create: if isAuth() && request.resource.data.userId == request.auth.uid;
    }

  }
}
