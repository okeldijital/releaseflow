{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "preserve",
    "incremental": true,
    "plugins": [{ "name": "next" }],
    "paths": {
      "@/*": ["./src/*"],
    "@releaseflow/core": ["../../packages/core/src/index.ts"],
    "@releaseflow/core/*": ["../../packages/core/src/*"],
    "@releaseflow/documents": ["../../packages/documents/src/index.ts"],
    "@releaseflow/documents/*": ["../../packages/documents/src/*"],
    "@releaseflow/firebase": ["../../packages/firebase/src/index.ts"],
    "@releaseflow/firebase/*": ["../../packages/firebase/src/*"],
    "@releaseflow/ui": ["../../packages/ui/src/index.ts"],
    "@releaseflow/ui/*": ["../../packages/ui/src/*"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules"]
}
